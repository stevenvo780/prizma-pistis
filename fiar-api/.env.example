# === Pistis API ===

# Servidor
NODE_ENV=development

# Base de datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5436
DB_NAME=pistis
DB_USERNAME=pistis_user
DB_PASSWORD=
DB_SYNCHRONIZE=true
# DEPRECATED (alias):
# DB_NAME=fiar
# DB_USERNAME=fiar_user

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# MercadoPago
MP_ACCESS_TOKEN=
MP_SANDBOX_MODE=true
MP_TEST_PAYER_EMAIL=

# URLs
APP_DOMAIN=http://localhost:3001
API_DOMAIN=http://localhost:8080

# Seguridad
ENCRYPTION_KEY=

# Prizma HubCentral (Nous)
NOUS_HUB_URL=
NOUS_HUB_SECRET=
NOUS_HUB_ENABLED=true
# DEPRECATED (aliases mantenidos para rollback):
# CAUCE_HUB_URL=
# CAUCE_HUB_SECRET=
# CAUCE_HUB_ENABLED=
